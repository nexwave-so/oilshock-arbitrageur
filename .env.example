# OilShock Arbitrageur — Environment Variables
# Copy to .env.local and fill in your values

# =============================================================================
# SOLANA AGENT WALLET (Required)
# =============================================================================

# Base64-encoded 64-byte secret key for the agent wallet.
# This wallet pays $0.001 USDC per signal fetch via x402 on Solana mainnet.
#
# Generate a new keypair:
#   node -e "const {Keypair}=require('@solana/web3.js'); const k=Keypair.generate(); console.log('Private Key (base64):', Buffer.from(k.secretKey).toString('base64')); console.log('Public Key:', k.publicKey.toString())"
#
# Fund the wallet with a small amount of mainnet USDC (~$0.10 is plenty for demo).
# The wallet also needs ~0.001 SOL for transaction fees.
SOLANA_PRIVATE_KEY=

# Solana mainnet — do not change for this project
SOLANA_NETWORK=solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# =============================================================================
# AI (Required)
# =============================================================================

# Anthropic API key — used by the agent for market analysis (Claude Sonnet 4.6)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
